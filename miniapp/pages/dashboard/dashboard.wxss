/* 统计区域 */
.stats-section { padding: 24rpx 24rpx 0; }
.stats-grid { display: flex; gap: 16rpx; }
.stat-card {
  flex: 1; background: var(--color-card); border-radius: var(--radius-lg);
  padding: 20rpx; text-align: center; box-shadow: var(--shadow-sm);
}
.stat-number { display: block; font-size: 40rpx; font-weight: 700; line-height: 1.2; }
.stat-label { display: block; font-size: var(--font-xs); color: var(--color-text-muted); margin-top: 4rpx; }

/* 筛选区域 */
.filter-section { padding: 24rpx; }
.filter-tabs { display: flex; gap: 12rpx; margin-bottom: 16rpx; }
.filter-tab {
  padding: 10rpx 24rpx; border-radius: 999rpx; font-size: var(--font-sm);
  background: var(--color-card); color: var(--color-text-secondary); border: 1rpx solid var(--color-border);
}
.filter-active { background: var(--color-primary); color: #fff; border-color: var(--color-primary); }

/* 任务列表 */
.task-list { padding: 0 24rpx 200rpx; }

/* 空状态文本 */
.empty-text-sm { font-size: var(--font-sm); color: var(--color-text-muted); text-align: center; padding: 40rpx; }

/* 浮动新建按钮 */
.fab {
  position: fixed; right: 40rpx; bottom: 140rpx;
  width: 108rpx; height: 108rpx; border-radius: 50%;
  background: linear-gradient(135deg, #3B82F6, #2563EB);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(59,130,246,0.4);
  z-index: 100;
}
.fab-icon { color: #fff; font-size: 52rpx; font-weight: 300; line-height: 1; }

/* 底部弹窗 */
.bottom-sheet {
  position: fixed; left: 0; right: 0; bottom: 0;
  background: #fff; border-radius: 32rpx 32rpx 0 0;
  z-index: 1000; transform: translateY(100%);
  transition: transform 0.3s ease; max-height: 85vh;
  display: flex; flex-direction: column;
}
.sheet-show { transform: translateY(0); }
.sheet-header { padding: 32rpx 32rpx 16rpx; border-bottom: 1rpx solid var(--color-border-light); }
.sheet-body { flex: 1; overflow-y: auto; padding: 24rpx 32rpx; max-height: 55vh; }
.sheet-footer { padding: 16rpx 32rpx 32rpx; border-top: 1rpx solid var(--color-border-light); }

/* 表单 */
.form-item { margin-bottom: 28rpx; }
.form-label { display: block; font-size: var(--font-sm); font-weight: 500; color: var(--color-text); margin-bottom: 12rpx; }
.form-input-box {
  display: flex; align-items: center; background: var(--color-bg);
  border: 2rpx solid var(--color-border); border-radius: var(--radius-md);
  padding: 0 24rpx; height: 88rpx; font-size: var(--font-md);
}
.form-textarea {
  background: var(--color-bg); border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md); padding: 20rpx 24rpx;
  font-size: var(--font-md); width: 100%; min-height: 120rpx;
}

/* 提交按钮 */
.submit-btn {
  width: 100%; height: 88rpx; background: linear-gradient(135deg, #3B82F6, #2563EB);
  color: #fff; font-size: var(--font-lg); font-weight: 600;
  border-radius: var(--radius-md); border: none;
}
.submit-btn[disabled] { background: #93C5FD; }

/* 操作弹窗 */
.action-sheet {
  position: fixed; left: 0; right: 0; bottom: 0;
  background: #fff; border-radius: 32rpx 32rpx 0 0;
  z-index: 1000; transform: translateY(100%);
  transition: transform 0.3s ease;
}
.action-sheet-header { padding: 32rpx; text-align: center; border-bottom: 1rpx solid var(--color-border-light); }
.action-sheet-body { padding: 16rpx 0; }
.action-item {
  padding: 28rpx 40rpx; font-size: var(--font-lg);
  border-bottom: 1rpx solid var(--color-border-light);
}
.action-item-danger { border-bottom: none; }
.action-cancel {
  padding: 28rpx; text-align: center; font-size: var(--font-lg);
  color: var(--color-text-secondary); border-top: 12rpx solid var(--color-bg);
}
