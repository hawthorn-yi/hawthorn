<view class="page-container login-page">
  <!-- 顶部装饰 -->
  <view class="login-header">
    <view class="logo-circle">
      <text class="logo-text">HP</text>
    </view>
    <text class="app-title">项目进度管理</text>
    <text class="app-subtitle">Hawthorn Project Tracker</text>
  </view>

  <!-- 登录表单 -->
  <view class="login-form">
    <view class="form-item">
      <text class="form-label">用户名</text>
      <view class="input-wrapper">
        <input
          class="form-input"
          placeholder="请输入用户名"
          value="{{username}}"
          bindinput="onUsernameInput"
          maxlength="20"
        />
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">密码</text>
      <view class="input-wrapper">
        <input
          class="form-input"
          placeholder="请输入密码"
          password="{{!showPassword}}"
          value="{{password}}"
          bindinput="onPasswordInput"
          maxlength="50"
        />
        <view class="toggle-password" bindtap="togglePassword">
          <text class="toggle-icon">{{showPassword ? '🙈' : '👁️'}}</text>
        </view>
      </view>
    </view>

    <button
      class="login-btn"
      bindtap="onLogin"
      loading="{{loading}}"
      disabled="{{loading}}"
    >
      登 录
    </button>

    <view class="register-link" bindtap="goRegister">
      <text class="text-secondary">还没有账号？</text>
      <text class="text-primary font-semibold">立即注册</text>
    </view>
  </view>
</view>
