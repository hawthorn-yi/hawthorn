.form-section { padding: 0 32rpx; }
.form-item { margin-bottom: 28rpx; }
.form-label { display: block; font-size: var(--font-sm); font-weight: 500; margin-bottom: 12rpx; }
.form-input-box { display: flex; align-items: center; background: var(--color-bg); border: 2rpx solid var(--color-border); border-radius: var(--radius-md); padding: 0 24rpx; height: 88rpx; font-size: var(--font-md); }
.submit-btn { width: 100%; height: 88rpx; background: linear-gradient(135deg, #3B82F6, #2563EB); color: #fff; font-size: var(--font-lg); font-weight: 600; border-radius: var(--radius-md); border: none; margin-top: 40rpx; }
.submit-btn[disabled] { background: #93C5FD; }
