.register-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #EFF6FF 0%, #F8FAFC 40%, #FFFFFF 100%);
  padding: 0 48rpx;
}

.register-header {
  padding-top: 120rpx;
  margin-bottom: 48rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #1E293B;
  margin-bottom: 8rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #94A3B8;
}

.register-form {
  flex: 1;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #334155;
  margin-bottom: 12rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border: 2rpx solid #E2E8F0;
  border-radius: var(--radius-lg);
  padding: 0 24rpx;
  height: 96rpx;
  transition: border-color 0.2s;
}

.input-wrapper:focus-within {
  border-color: #3B82F6;
}

.form-input {
  flex: 1;
  height: 96rpx;
  font-size: 30rpx;
  color: #334155;
}

.toggle-password {
  padding: 16rpx;
}

.toggle-icon {
  font-size: 32rpx;
}

.register-btn {
  margin-top: 40rpx;
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #3B82F6, #2563EB);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: var(--radius-lg);
  border: none;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.3);
}

.register-btn[disabled] {
  background: #93C5FD;
  box-shadow: none;
}

.login-link {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
  margin-top: 32rpx;
  padding: 16rpx;
}
