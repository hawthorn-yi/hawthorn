.filter-scroll { white-space: nowrap; padding: 24rpx; }
.user-filter { display: inline-block; padding: 10rpx 24rpx; border-radius: 999rpx; font-size: var(--font-sm); background: #fff; border: 1rpx solid var(--color-border); margin-right: 12rpx; }
