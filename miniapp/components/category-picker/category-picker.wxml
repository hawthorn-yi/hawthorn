<view class="category-picker">
  <text class="form-label">分类</text>
  <view class="category-list">
    <view class="category-item {{item.id === selectedId ? 'category-active' : ''}}"
      wx:for="{{categories}}" wx:key="id" bindtap="onSelect" data-id="{{item.id}}">
      <view class="color-dot" style="background-color:{{item.color}}"></view>
      <text class="category-name">{{item.name}}</text>
      <text wx:if="{{item.id === selectedId}}" class="check-mark">✓</text>
    </view>
  </view>
</view>
